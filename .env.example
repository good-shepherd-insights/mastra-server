# ─── Auth Gateway ────────────────────────────────────────────────────────────
# Consumer-facing key — all API requests must include this as a Bearer token
AUTH_GATEWAY_API_KEY=

# ─── Upstream LLM Providers ──────────────────────────────────────────────────
# Used internally by the auth gateway to call upstream providers
FEATHERLESS_API_KEY=
PIONEER_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# ─── Mastra Cloud ────────────────────────────────────────────────────────────
# Optional — enables trace export to Mastra Cloud
MASTRA_CLOUD_ACCESS_TOKEN=

# ─── Slack OAuth (MCP server) ────────────────────────────────────────────────
# Single Slack app used for the MCP OAuth flow
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URL=

# ─── Research Manager (Slack bot) ────────────────────────────────────────────
# Separate Slack app — webhook: /api/agents/research-manager/channels/slack/webhook
RESEARCH_MANAGER_SLACK_BOT_TOKEN=
RESEARCH_MANAGER_SLACK_SIGNING_SECRET=

# ─── Operations Manager (Slack bot) ──────────────────────────────────────────
# Separate Slack app — webhook: /api/agents/operations-manager/channels/slack/webhook
OPS_MANAGER_SLACK_BOT_TOKEN=
OPS_MANAGER_SLACK_SIGNING_SECRET=

# ─── QA Manager (Slack bot) ──────────────────────────────────────────────────
# Separate Slack app — webhook: /api/agents/qa-manager/channels/slack/webhook
QA_MANAGER_SLACK_BOT_TOKEN=
QA_MANAGER_SLACK_SIGNING_SECRET=
